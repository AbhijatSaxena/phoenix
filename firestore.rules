rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Each user can read their own role document; only admins can write
    match /users/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow write: if isAdmin();
    }

    // Sessions: users manage their own, admins can read all and revoke any
    match /sessions/{sessionId} {
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow read, delete: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // Everything else: authenticated users can read, only admins can write
    match /{document=**} {
      allow read:  if isAuth();
      allow write: if isAdmin();
    }
  }
}
